# ── Local dev needs NO env at all ───────────────────────────────────────────
# Without any variables set, the API uses a plain SQLite file at
# server/data/parkingfriend.db (libsql "file:" mode).

# Port the API listens on (default 4000)
PORT=4000

# Secret used to sign JWTs — change this in production!
JWT_SECRET=parkingfriend-dev-secret

# ── Production: Turso (free cloud SQLite via libsql) ────────────────────────
# Create the db once (see README):
#   turso db create parkingfriend
#   turso db show parkingfriend --url        -> TURSO_DATABASE_URL (libsql://...)
#   turso db tokens create parkingfriend     -> TURSO_AUTH_TOKEN
# TURSO_DATABASE_URL=libsql://parkingfriend-<your-org>.turso.io
# TURSO_AUTH_TOKEN=
