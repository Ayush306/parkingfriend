{
  "expo": {
    "name": "Parkmitter",
    "slug": "parkmitter",
    "scheme": "parkmitter",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parkmitter.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Parkmitter uses your location to find parking spots near you and to let you pin your own space on the map."
      }
    },
    "android": {
      "package": "com.parkmitter.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0FB57E"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 160,
          "backgroundColor": "#0FB57E",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Parkmitter uses your location to find parking spots near you and to let you pin your own space on the map."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "af06a94e-ba6c-443e-bb63-9a3e91e127f2"
      }
    }
  }
}
