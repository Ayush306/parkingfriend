{
  "expo": {
    "name": "Parkmitter",
    "slug": "parkmitter",
    "scheme": "parkmitter",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#0FB57E",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parkmitter.app"
    },
    "android": {
      "package": "com.parkmitter.app",
      "adaptiveIcon": {
        "backgroundColor": "#0FB57E"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ],
    "newArchEnabled": false
  }
}
